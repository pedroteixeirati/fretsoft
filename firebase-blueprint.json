{
  "entities": {
    "Vehicle": {
      "title": "Veículo",
      "description": "Um veículo da frota",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Nome do veículo" },
        "plate": { "type": "string", "description": "Placa do veículo" },
        "driver": { "type": "string", "description": "Motorista responsável" },
        "type": { "type": "string", "description": "Tipo do veículo" },
        "km": { "type": "number", "description": "Quilometragem atual" },
        "nextMaintenance": { "type": "string", "description": "Data da próxima manutenção" },
        "status": { "type": "string", "enum": ["active", "maintenance", "alert"], "description": "Status do veículo" },
        "efficiency": { "type": "number", "description": "Eficiência de combustível" },
        "fuelType": { "type": "string", "description": "Tipo de combustível" },
        "license": { "type": "string", "description": "Licenciamento" },
        "healthScore": { "type": "number", "description": "Pontuação de saúde" },
        "image": { "type": "string", "description": "URL da imagem" },
        "uid": { "type": "string", "description": "UID do dono do documento" }
      },
      "required": ["name", "plate", "driver", "type", "km", "status", "uid"]
    },
    "Expense": {
      "title": "Despesa",
      "description": "Uma despesa de veículo",
      "type": "object",
      "properties": {
        "date": { "type": "string", "description": "Data da despesa" },
        "time": { "type": "string", "description": "Hora da despesa" },
        "vehicleId": { "type": "string", "description": "ID do veículo" },
        "vehicleName": { "type": "string", "description": "Nome do veículo" },
        "provider": { "type": "string", "description": "Fornecedor" },
        "category": { "type": "string", "description": "Categoria da despesa" },
        "quantity": { "type": "string", "description": "Quantidade" },
        "amount": { "type": "number", "description": "Valor total" },
        "odometer": { "type": "string", "description": "Odômetro no momento" },
        "status": { "type": "string", "enum": ["approved", "review", "pending"], "description": "Status da despesa" },
        "observations": { "type": "string", "description": "Observações" },
        "uid": { "type": "string", "description": "UID do dono do documento" }
      },
      "required": ["date", "vehicleId", "category", "amount", "uid"]
    },
    "Provider": {
      "title": "Fornecedor",
      "description": "Um fornecedor de serviços",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Nome do fornecedor" },
        "type": { "type": "string", "description": "Tipo do fornecedor" },
        "rating": { "type": "number", "description": "Avaliação" },
        "status": { "type": "string", "description": "Status da parceria" },
        "contact": { "type": "string", "description": "Contato" },
        "uid": { "type": "string", "description": "UID do dono do documento" }
      },
      "required": ["name", "type", "uid"]
    },
    "User": {
      "title": "Usuário",
      "description": "Perfil do usuário e nível de acesso",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "UID do usuário" },
        "email": { "type": "string", "description": "E-mail do usuário" },
        "role": { "type": "string", "enum": ["admin", "driver", "viewer"], "description": "Nível de acesso" },
        "name": { "type": "string", "description": "Nome do usuário" },
        "createdAt": { "type": "string", "description": "Data de criação" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/vehicles/{vehicleId}": {
      "schema": "Vehicle",
      "description": "Coleção de veículos"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Coleção de despesas"
    },
    "/providers/{providerId}": {
      "schema": "Provider",
      "description": "Coleção de fornecedores"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Coleção de perfis de usuários"
    }
  }
}
