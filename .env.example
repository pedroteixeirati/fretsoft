# GEMINI_API_KEY: Required for summary generation.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Backend API URL for local development
VITE_API_URL="http://localhost:3001"

# Backend bind address
HOST="127.0.0.1"

# PostgreSQL connection string
DATABASE_URL="postgresql://fretsoft_user:postgres@localhost:5432/fretsoft_prod"

# Firebase Admin credentials for backend token validation
FIREBASE_ADMIN_PROJECT_ID="my-firebase-project-id"
FIREBASE_ADMIN_CLIENT_EMAIL="firebase-adminsdk@my-project.iam.gserviceaccount.com"
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Kill-switch global do módulo fiscal. "false" desliga o fiscal para TODOS os tenants,
# independente dos feature flags por transportadora (tenant_features). Default: true.
FISCAL_MODULE_ENABLED="true"

# Piso minimo de frete (R$) para alerta nao-bloqueante ao pagar TAC. 0 = desligado.
# Simplificacao ate integrar as tabelas oficiais da ANTT (distancia/eixos/carga).
FISCAL_PISO_MIN_FREIGHT="0"

# Fiscal document provider (CT-e / CT-e OS / MDF-e)
# Use "mock_fiscal" to test the full internal flow locally without a real account/token.
# Use "focus_nfe" once you have a Focus NFe account.
FISCAL_PROVIDER="mock_fiscal"

# Focus NFe credentials (only required when FISCAL_PROVIDER=focus_nfe)
FOCUS_NFE_TOKEN=""
# Environment: "homologacao" (default) or "producao"
FOCUS_NFE_ENV="homologacao"
# Optional override for the Focus NFe base URL (defaults derived from FOCUS_NFE_ENV)
FOCUS_NFE_BASE_URL=""
