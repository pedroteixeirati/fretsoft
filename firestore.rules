rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: vehicles
    // Fields: name, plate, driver, type, km, nextMaintenance, status, uid, ...
    //
    // Collection: expenses
    // Fields: date, time, vehicleId, vehicleName, provider, category, quantity, amount, odometer, status, observations, uid
    //
    // Collection: providers
    // Fields: name, type, rating, status, contact, uid
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isDev() {
      return isAuthenticated() &&
        (request.auth.token.email == "pedroteixeirati@hotmail.com" || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dev'));
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "pedroteixeirati@gmail.com" || 
         isDev() ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidVehicle(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.plate is string && data.plate.size() > 0 && data.plate.size() < 20 &&
             data.driver is string && data.driver.size() > 0 && data.driver.size() < 100 &&
             data.type is string &&
             data.km is number && data.km >= 0 &&
             data.status in ['active', 'maintenance', 'alert'];
    }

    function isValidExpense(data) {
      return data.date is string &&
             data.vehicleId is string &&
             data.category is string &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['approved', 'review', 'pending'];
    }

    function isValidProvider(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.type is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Dev users have full access to everything
    match /{document=**} {
      allow read, write: if isDev();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && (isOwner(userId) || isDev());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && uidNotModified() && (request.resource.data.role == resource.data.role || isDev());
      allow delete: if isDev();
    }

    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidVehicle(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isValidVehicle(request.resource.data) && (isDocOwner() || isAdmin()) && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidExpense(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isValidExpense(request.resource.data) && (isDocOwner() || isAdmin()) && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /providers/{providerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidProvider(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isValidProvider(request.resource.data) && (isDocOwner() || isAdmin()) && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }
  }
}
